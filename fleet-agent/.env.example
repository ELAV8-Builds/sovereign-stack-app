# Fleet Agent Configuration
# Copy to .env and fill in values

# === Required ===
OVERMIND_URL=http://192.168.1.60:3100
FLEET_NAME=mac-mini
MACHINE_NAME=Beau-Mac-Mini
FLEET_API_KEY=flk_...
FLEET_HMAC_SECRET=hms_...

# === Optional ===
PORT=3300
REGION=home-lan
MAX_WORKERS=3

# Capabilities (comma-separated)
CAPABILITIES=docker,node,python,git

# IP of this machine (for registration)
# FLEET_IP=192.168.1.50

# TLS (optional — for remote/cloud deployments)
# TLS_CERT=/path/to/cert.pem
# TLS_KEY=/path/to/key.pem

# Docker socket (default: /var/run/docker.sock)
# DOCKER_SOCKET=/var/run/docker.sock
