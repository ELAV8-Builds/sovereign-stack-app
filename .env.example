# ============================================================
# Sovereign Stack — Environment Configuration
# ============================================================
# Copy to .env and fill in your API keys.
# Only ANTHROPIC_API_KEY is required — everything else has defaults.
# ============================================================

# ── Required: At least one LLM provider ──────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Additional LLM providers ───────────────────
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AI...

# ── LiteLLM (model router) ──────────────────────────────
LITELLM_MASTER_KEY=sk-litellm-master

# ── Infrastructure defaults (for native API mode) ───────
DATABASE_URL=postgresql://sovereign:sovereign@localhost:5432/sovereign
REDIS_URL=redis://localhost:6379
LITELLM_URL=http://localhost:4000
MEMU_URL=http://localhost:8090
OLLAMA_URL=http://localhost:11434
ANYTHINGLLM_URL=http://localhost:3001

# ── API server ──────────────────────────────────────────
PORT=3100
WORKSPACE_ROOT=~/projects
